# ============================================================
# CELLAR 54 — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Vite rules:
#   VITE_*  → exposed to the browser (client-safe only)
#   No prefix → server/serverless only (keep secret)
# ============================================================


# ------------------------------------------------------------
# GOOGLE CALENDAR
# ------------------------------------------------------------
# Public API key — used to READ calendar events in the browser
VITE_GOOGLE_CALENDAR_API_KEY=

# The Calendar ID to display (found in Google Calendar settings)
VITE_GOOGLE_CALENDAR_ID=

# OAuth credentials — needed if you write events (e.g., booking confirmation)
# Generate at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=


# ------------------------------------------------------------
# STRIPE
# ------------------------------------------------------------
# Publishable key — safe to expose in the browser
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_

# Secret key — NEVER expose this in the browser, server/serverless only
STRIPE_SECRET_KEY=sk_live_

# Webhook signing secret — verifies events sent from Stripe to your endpoint
STRIPE_WEBHOOK_SECRET=whsec_


# ------------------------------------------------------------
# EMAIL — FORM SUBMISSIONS
# Choose one approach: EmailJS (client-side) OR SMTP/API (server-side)
# ------------------------------------------------------------

# -- Option A: EmailJS (no backend required) --
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# -- Option B: SMTP / Transactional Email (server/serverless only) --
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=no-reply@cellar54.com
EMAIL_TO=info@cellar54.com

# -- Option C: SendGrid API (server/serverless only) --
SENDGRID_API_KEY=

# -- Option D: Resend API (server/serverless only) --
RESEND_API_KEY=
